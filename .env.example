# World Cup Intelligence Platform — Environment Variables
# Copy to .env and fill in your values.

# --- Azure AI Foundry (Hosted Agent) ---
FOUNDRY_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o
FOUNDRY_TOOLBOX_ENDPOINT=

# --- MCP Server URL (for agent → MCP calls) ---
# Local: http://localhost:8000/mcp/
# Docker Compose: http://mcp-server:8000/mcp/
MCP_SERVER_URL=http://localhost:8000/mcp/

# --- API-Football v3 ---
FOOTBALL_API_KEY=your-api-football-key-here

# --- Database (PostgreSQL) ---
# Local: postgresql://postgres:postgres@localhost:5432/worldcup
# Docker Compose: postgresql://postgres:postgres@postgres:5432/worldcup
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/worldcup
